---
import Layout from './Layout.astro';
import { LogOut } from 'lucide-react';

interface Props {
  title: string;
  role: 'profesor' | 'estudiante';
  userName?: string;
  sessionCode?: string;
}

const { title, role, userName = 'Usuario', sessionCode } = Astro.props;
---

<Layout title={title}>
  <div class="min-h-screen flex flex-col bg-slate-100">
    <!-- Navbar -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-30">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex items-center gap-4">
            <div class="flex-shrink-0 flex items-center gap-2">
              <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
                <span class="text-white font-bold text-sm">SP</span>
              </div>
              <span class="font-bold text-xl text-slate-800">Simulador</span>
            </div>
            {
              sessionCode && (
                <div class="hidden md:flex items-center gap-2 ml-4 px-3 py-1 bg-slate-100 rounded-full border border-slate-200">
                  <span class="text-xs text-slate-500 font-medium">Sesión:</span>
                  <span class="text-sm font-bold text-slate-800 tracking-wider">{sessionCode}</span>
                </div>
              )
            }
          </div>

          <div class="flex items-center gap-4">
            <div class="text-right hidden sm:block">
              <p class="text-sm font-medium text-slate-900">{userName}</p>
              <p class="text-xs text-slate-500 capitalize">{role}</p>
            </div>
            <a
              href="/"
              class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-full transition-colors"
              title="Salir"
            >
              <LogOut size={20} />
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>
  </div>
</Layout>
