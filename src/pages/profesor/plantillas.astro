---
import ProfesorLayout from '../../layouts/ProfesorLayout.astro';
import { Shapes, Plus, Package, Landmark, ChevronRight } from 'lucide-react';
import { supabase } from '../../lib/supabase';
import { checkProfessorAuth } from '../../lib/auth';

const auth = await checkProfessorAuth(Astro);
if (auth.redirect) {
  return Astro.redirect(auth.redirect);
}

const user = auth.user;

// Obtener plantillas con sus items, rubros y conteo de reglas bancarias
const { data: templates } = await supabase
  .from('game_templates')
  .select(
    `
    *,
    template_items(*),
    template_production_rubrics(*),
    template_bank_rules(count)
  `
  )
  .order('created_at', { ascending: false });
---

<ProfesorLayout title="Plantillas | Profesor" activePath="/profesor/plantillas" user={user}>
  <div class="max-w-6xl mx-auto pb-20 px-4">
    <header class="mb-12 flex flex-col md:flex-row md:items-center justify-between gap-6">
      <div>
        <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">Plantillas de Juego</h1>
        <p class="text-lg text-slate-500 mt-2 font-medium italic">
          Configura catálogos de materiales, herramientas, rubros y reglas bancarias.
        </p>
      </div>
      <a
        href="/profesor/plantillas/nueva"
        class="group inline-flex items-center justify-center px-6 py-4 bg-indigo-600 text-white font-bold rounded-2xl hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-200 hover:-translate-y-1 active:scale-95 gap-3"
      >
        <div class="p-1 bg-white/20 rounded-lg group-hover:bg-white/30 transition-colors">
          <Plus size={20} />
        </div>
        Nueva Plantilla
      </a>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
      {
        templates &&
          templates.map((tpl: any) => (
            <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden hover:shadow-2xl hover:shadow-indigo-500/5 transition-all duration-500 group flex flex-col border-b-4 border-b-indigo-500/10">
              <div class="p-10 flex-1">
                <div class="flex justify-between items-start mb-8">
                  <div class="w-16 h-16 bg-gradient-to-br from-indigo-50 to-white rounded-3xl flex items-center justify-center text-indigo-600 shadow-sm group-hover:from-indigo-600 group-hover:to-indigo-500 group-hover:text-white transition-all duration-500 transform group-hover:rotate-6">
                    <Shapes size={32} />
                  </div>
                  <div class="flex flex-col items-end gap-2">
                    <span
                      class={`text-[10px] font-bold uppercase px-3 py-1.5 rounded-xl border ${tpl.is_active ? 'bg-green-50 text-green-700 border-green-100' : 'bg-slate-50 text-slate-400 border-slate-100'}`}
                    >
                      {tpl.is_active ? 'Activa' : 'Inactiva'}
                    </span>
                    <p class="text-[10px] font-bold text-slate-400 tracking-widest uppercase">
                      ID: {tpl.id.substring(0, 8)}
                    </p>
                  </div>
                </div>

                <h3 class="text-3xl font-black text-slate-900 group-hover:text-indigo-600 transition-colors leading-tight">
                  {tpl.name}
                </h3>

                <div class="flex flex-wrap items-center gap-2 mt-4 text-[10px] font-black uppercase tracking-wider">
                  <div class="px-3 py-1 bg-blue-50 rounded-lg text-blue-600 border border-blue-100/50">
                    Interés: <span class="text-blue-900">{tpl.interest_rate}%</span>
                  </div>
                  <div class="px-3 py-1 bg-indigo-50 rounded-lg text-indigo-600 border border-indigo-100/50">
                    Efectivo Inicial: <span class="text-indigo-900">${tpl.starting_cash}</span>
                  </div>
                </div>

                <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-8">
                  {/* Preview Bodega */}
                  <div class="space-y-4">
                    <div class="flex items-center justify-between text-slate-800 font-bold text-sm">
                      <div class="flex items-center gap-2">
                        <Package size={18} class="text-amber-500" />
                        Bodega
                      </div>
                      <span class="text-[10px] bg-slate-100 px-2 py-0.5 rounded-md text-slate-500">
                        {tpl.template_items?.length || 0} items
                      </span>
                    </div>
                    <div class="space-y-2">
                      {tpl.template_items?.slice(0, 3).map((item: any) => (
                        <div class="flex justify-between items-center text-xs py-2 px-3 bg-slate-50/50 rounded-xl border border-slate-50 group-hover:bg-white group-hover:border-slate-100 transition-all">
                          <span class="text-slate-600 font-medium truncate pr-2">{item.name}</span>
                          <span class="text-slate-900 font-bold">${item.price}</span>
                        </div>
                      ))}
                      {tpl.template_items?.length > 3 && (
                        <p class="text-[10px] text-slate-400 font-bold pl-3">
                          +{tpl.template_items.length - 3} más...
                        </p>
                      )}
                      {(!tpl.template_items || tpl.template_items.length === 0) && (
                        <p class="text-xs text-slate-400 italic pl-3">No hay materiales</p>
                      )}
                    </div>
                  </div>

                  {/* Preview Rubros y Banco */}
                  <div class="space-y-6">
                    <div class="space-y-4">
                      <div class="flex items-center justify-between text-slate-800 font-bold text-sm">
                        <div class="flex items-center gap-2">
                          <Landmark size={18} class="text-emerald-500" />
                          Rubros Venta
                        </div>
                        <span class="text-[10px] bg-slate-100 px-2 py-0.5 rounded-md text-slate-500">
                          {tpl.template_production_rubrics?.length || 0} rubros
                        </span>
                      </div>
                      <div class="space-y-2">
                        {tpl.template_production_rubrics?.slice(0, 2).map((rubric: any) => (
                          <div class="flex justify-between items-center text-xs py-2 px-3 bg-slate-50/50 rounded-xl border border-slate-50 group-hover:bg-white group-hover:border-slate-100 transition-all">
                            <span class="text-slate-600 font-medium truncate pr-2">
                              {rubric.label}
                            </span>
                            <span class="text-emerald-600 font-bold">${rubric.price_per_unit}</span>
                          </div>
                        ))}
                        {tpl.template_production_rubrics?.length > 2 && (
                          <p class="text-[10px] text-slate-400 font-bold pl-3">
                            +{tpl.template_production_rubrics.length - 2} más...
                          </p>
                        )}
                        {(!tpl.template_production_rubrics ||
                          tpl.template_production_rubrics.length === 0) && (
                          <p class="text-xs text-slate-400 italic pl-3">No hay rubros</p>
                        )}
                      </div>
                    </div>

                    <div class="flex items-center justify-between p-3 bg-indigo-50/30 rounded-2xl border border-indigo-100/50 group-hover:bg-white transition-all">
                      <div class="flex items-center gap-3 text-slate-600">
                        <Landmark size={18} class="text-indigo-400" />
                        <span class="text-xs font-bold text-slate-700">Reglas Banco</span>
                      </div>
                      <span class="text-[10px] font-black bg-indigo-600 text-white px-2.5 py-1 rounded-lg">
                        {tpl.template_bank_rules?.[0]?.count || 0} ESCALAS
                      </span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="px-10 py-8 bg-slate-50/50 border-t border-slate-100 flex items-center justify-between group-hover:bg-white transition-all duration-300">
                <button class="text-sm font-bold text-slate-400 hover:text-red-500 transition-colors uppercase tracking-widest">
                  Eliminar
                </button>
                <div class="flex gap-3">
                  <a
                    href={`/profesor/plantillas/${tpl.id}`}
                    class="px-6 py-3 bg-white border-2 border-slate-100 rounded-2xl text-sm font-bold text-slate-600 hover:border-indigo-600 hover:text-indigo-600 transition-all flex items-center gap-2"
                  >
                    Gestionar
                    <ChevronRight size={16} />
                  </a>
                </div>
              </div>
            </div>
          ))
      }

      {/* Empty State */}
      {
        (!templates || templates.length === 0) && (
          <div class="col-span-full py-32 bg-white border-4 border-dashed border-slate-100 rounded-[3rem] flex flex-col items-center justify-center text-center">
            <div class="w-24 h-24 bg-slate-50 rounded-3xl flex items-center justify-center mb-6 text-slate-200">
              <Shapes size={48} />
            </div>
            <h3 class="text-2xl font-black text-slate-800">No hay plantillas creadas</h3>
            <p class="text-slate-400 mt-2 max-w-xs mx-auto font-medium">
              Comienza creando una plantilla base para tus simulaciones.
            </p>
            <button class="mt-8 px-8 py-4 bg-indigo-600 text-white font-bold rounded-2xl shadow-xl shadow-indigo-100">
              Crear Plantilla Ahora
            </button>
          </div>
        )
      }
    </div>
  </div>
</ProfesorLayout>
