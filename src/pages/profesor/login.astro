---
import Layout from '../../layouts/Layout.astro';
import { ArrowLeft, LogIn } from 'lucide-react';
import { supabase } from '../../lib/supabase';

let errorMessage = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const email = data.get('email')?.toString();
    const password = data.get('password')?.toString();

    if (!email || !password) {
      errorMessage = 'Por favor ingrese email y contraseña';
    } else {
      const { data: authData, error } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (error) {
        errorMessage = 'Credenciales incorrectas o usuario no encontrado.';
      } else if (authData.session) {
        const { access_token, refresh_token } = authData.session;
        Astro.cookies.set('sb-access-token', access_token, {
          path: '/',
          secure: true,
          httpOnly: true,
          sameSite: 'lax',
        });
        Astro.cookies.set('sb-refresh-token', refresh_token, {
          path: '/',
          secure: true,
          httpOnly: true,
          sameSite: 'lax',
        });
        return Astro.redirect('/profesor');
      }
    }
  } catch (error) {
    if (error instanceof Error) {
      errorMessage = error.message;
    }
  }
}
---

<Layout title="Profesor | Iniciar Sesión">
  <div
    class="min-h-screen bg-slate-50 p-6 flex items-center justify-center relative overflow-hidden"
  >
    <div
      class="absolute inset-0 bg-indigo-50 opacity-50 [mask-image:radial-gradient(circle_at_top_left,black,transparent_50%)] pointer-events-none"
    >
    </div>

    <div class="max-w-md w-full relative z-10">
      <div class="mb-8">
        <a
          href="/"
          class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors"
        >
          <ArrowLeft size={16} class="mr-2" />
          Volver al inicio
        </a>
      </div>

      <div
        class="bg-white rounded-2xl shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden"
      >
        <div class="p-8">
          <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center mb-6">
            <LogIn class="text-indigo-600" size={24} />
          </div>

          <h1 class="text-2xl font-bold text-slate-900 mb-2">Acceso Profesores</h1>
          <p class="text-slate-500 mb-8">
            Ingresa con tus credenciales para administrar tus sesiones.
          </p>

          {
            errorMessage && (
              <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm">
                {errorMessage}
              </div>
            )
          }

          <form class="space-y-5" method="POST">
            <div>
              <label for="email" class="block text-sm font-medium text-slate-700 mb-2">
                Correo Electrónico
              </label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="ejemplo@universidad.edu"
                required
                class="block w-full rounded-xl border-slate-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 bg-slate-50 border p-3 text-slate-900"
              />
            </div>

            <div>
              <label for="password" class="block text-sm font-medium text-slate-700 mb-2">
                Contraseña
              </label>
              <input
                type="password"
                id="password"
                name="password"
                placeholder="••••••••"
                required
                class="block w-full rounded-xl border-slate-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 bg-slate-50 border p-3 text-slate-900"
              />
            </div>

            <button
              type="submit"
              class="w-full flex justify-center items-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors gap-2 mt-2"
            >
              <LogIn size={18} />
              Iniciar Sesión
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</Layout>
