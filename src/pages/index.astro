---
import Layout from '../layouts/Layout.astro';
import { BookOpen, Users, ArrowRight } from 'lucide-react';
---

<Layout title="Simulador de Procesos | Bienvenida">
  <main
    class="min-h-screen flex items-center justify-center bg-slate-50 p-4 relative overflow-hidden"
  >
    <!-- Decoración de fondo -->
    <div
      class="absolute inset-0 bg-blue-100 opacity-20 [mask-image:radial-gradient(circle_at_center,black,transparent_80%)] pointer-events-none"
    >
    </div>

    <div class="w-full max-w-4xl grid md:grid-cols-2 gap-6 relative z-10">
      <!-- Lado Izquierdo: Intro -->
      <div class="flex flex-col justify-center pr-8 pb-8 md:pb-0">
        <div
          class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mb-6 shadow-lg shadow-blue-500/30"
        >
          <span class="text-white font-bold text-xl">SP</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 tracking-tight leading-tight mb-4">
          Simulador de <span class="text-blue-600">Procesos</span>
        </h1>
        <p class="text-lg text-slate-500 mb-8 max-w-md leading-relaxed">
          Plataforma de simulación interactiva. Aprende gestión financiera, planificación y control
          de producción en tiempo real.
        </p>
      </div>

      <!-- Lado Derecho: Selección de Rol -->
      <div class="flex flex-col gap-4 justify-center">
        <a
          href="/profesor"
          class="group flex items-center justify-between p-6 bg-white rounded-2xl border border-slate-200 hover:border-blue-300 hover:shadow-xl hover:shadow-blue-500/10 transition-all duration-300 transform hover:-translate-y-1"
        >
          <div class="flex items-center gap-4">
            <div
              class="p-4 bg-indigo-50 text-indigo-600 rounded-xl group-hover:scale-110 transition-transform"
            >
              <BookOpen size={28} strokeWidth={1.5} />
            </div>
            <div>
              <h2 class="text-xl font-semibold text-slate-800 mb-1">Soy Profesor</h2>
              <p class="text-sm text-slate-500">Administrar sesiones y evaluar</p>
            </div>
          </div>
          <ArrowRight
            class="text-slate-300 group-hover:text-blue-500 transform group-hover:translate-x-1 transition-all"
          />
        </a>

        <a
          href="/estudiante"
          class="group flex items-center justify-between p-6 bg-white rounded-2xl border border-slate-200 hover:border-blue-300 hover:shadow-xl hover:shadow-blue-500/10 transition-all duration-300 transform hover:-translate-y-1"
        >
          <div class="flex items-center gap-4">
            <div
              class="p-4 bg-emerald-50 text-emerald-600 rounded-xl group-hover:scale-110 transition-transform"
            >
              <Users size={28} strokeWidth={1.5} />
            </div>
            <div>
              <h2 class="text-xl font-semibold text-slate-800 mb-1">Soy Estudiante</h2>
              <p class="text-sm text-slate-500">Unirme a una sesión activa</p>
            </div>
          </div>
          <ArrowRight
            class="text-slate-300 group-hover:text-blue-500 transform group-hover:translate-x-1 transition-all"
          />
        </a>
      </div>
    </div>
  </main>
</Layout>
