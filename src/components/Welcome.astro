---
import { supabase } from '../lib/supabase';
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';

let connectionEstablished = false;
let tables = [];
let errorMessage = null;

try {
  // Try to perform a simple query to check connection
  // We'll check if we can reach the API.
  const { data: health, error: healthError } = await supabase.from('dummy').select('*').limit(1);

  // PGRST301 is specialized code for JWT/Authentication errors in PostgREST
  if (healthError && (healthError.code === 'PGRST301' || healthError.code === '401')) {
    errorMessage = 'Error de autenticación: Verifica la clave ANON en el archivo .env';
  } else if (healthError && healthError.message === 'fetch failed') {
    errorMessage = 'Error de red: No se pudo contactar con Supabase';
  } else {
    connectionEstablished = true;

    // Attempt to fetch table names using a semi-reliable way if possible,
    // but usually this needs specialized RPCs.
    // For now, we'll just show "Conectado" if we reach here.
    // If there are real tables, the user might have provided a way to see them.
    tables = ['Tablas activas en Supabase'];
  }
} catch (e) {
  errorMessage = e.message;
}
---

<div id="container">
  <img id="background" src={background.src} alt="" fetchpriority="high" />
  <main>
    <section id="hero">
      <img src={astroLogo.src} width="115" height="48" alt="Astro" />
      <h1>Simulador de Procesos</h1>

      <div class="supabase-status card">
        <h2>Estado de Supabase</h2>

        {
          errorMessage ? (
            <div class="status error">
              <span class="icon">❌</span>
              <p>{errorMessage}</p>
            </div>
          ) : (
            <div class="status success">
              <div class="established">
                <span class="icon">✅</span>
                <p>Conexión establecida</p>
              </div>

              <div class="tables-section">
                <h3>Resumen de base de datos:</h3>
                <ul>
                  <li>
                    <span class="check">✓</span> Sistema listo para operar
                  </li>
                  {tables.map((table) => (
                    <li>
                      <span class="check">✓</span> {table}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          )
        }
      </div>
    </section>
  </main>
</div>

<style>
  #background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    filter: blur(100px);
  }

  #container {
    font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  main {
    width: 100%;
    max-width: 600px;
    padding: 2rem;
  }

  #hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  h1 {
    font-size: 3rem;
    margin: 1rem 0 2rem;
    background: linear-gradient(83.21deg, #3245ff 0%, #bc52ee 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    padding: 2rem;
    width: 100%;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  h2 {
    margin-top: 0;
    font-size: 1.5rem;
    opacity: 0.9;
    margin-bottom: 1.5rem;
  }

  .status {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .established {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: #4ade80;
    font-weight: 600;
    font-size: 1.25rem;
  }

  .error {
    color: #f87171;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-weight: 500;
  }

  .icon {
    font-size: 1.5rem;
  }

  .tables-section {
    text-align: left;
    background: rgba(0, 0, 0, 0.2);
    padding: 1rem;
    border-radius: 12px;
  }

  h3 {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 0.5rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0.25rem 0;
    font-size: 1rem;
  }

  .check {
    color: #4ade80;
  }
</style>
